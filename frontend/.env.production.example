# Copy to Vercel → Project Settings → Environment Variables (Production + Preview).
# Rebuild/redeploy the frontend after changing this value.
#
# Split stack: Vercel hosts the UI; the API runs on your Windows server and is
# exposed via Cloudflare Tunnel (or similar). Use the tunnel hostname only —
# do NOT append /health or /api/v1 (the app adds /api automatically).
#
# Example:
#   VITE_API_BASE=https://your-subdomain.trycloudflare.com/api
#
# Or hostname only (https:// is added at build time):
#   VITE_API_BASE=your-subdomain.trycloudflare.com
#
# Wrong (will break admin pages):
#   VITE_API_BASE=https://your-subdomain.trycloudflare.com/health
#   VITE_API_BASE=https://your-subdomain.trycloudflare.com/api/v1

VITE_API_BASE=https://your-tunnel-host.trycloudflare.com/api
