# Local API + Vercel UI + Supabase/Neon Postgres
#
# Setup:
#   1. Copy this file to backend/.env
#   2. Set DATABASE_URL to your production Supabase or Neon connection string
#   3. Set JWT_SECRET and COOKIE_SECRET (use existing production values to keep logins valid)
#   4. Expose this machine with a tunnel (see README §16.1) and set Vercel VITE_API_BASE
#
# Do NOT run docker compose for Postgres when using Supabase/Neon — that would be a different database.

PORT=5001
NODE_ENV=production
SERVE_FRONTEND=false

# Supabase or Neon connection string (must match production exactly)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Use existing production secrets so login sessions keep working
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# Your Vercel production URL (exact origin, no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Required when UI (Vercel) and API (this machine) are on different hosts
COOKIE_SAME_SITE=none

CSRF_ENABLED=true
ACTIVITY_LOG_ENABLED=true
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=6
OFFICE_RADIUS_METERS=500
OFFICE_RADIUS_GPS_BUFFER_CAP_METERS=200
MAX_GPS_ACCURACY_METERS=400
MAX_CLIENT_CLOCK_SKEW_MS=300000
MAX_IMPOSSIBLE_SPEED_MPS=50
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info
ATTENDANCE_CALENDAR_TZ=Asia/Jakarta
FIELD_OFFICER_CHECKOUT_KEYWORD=PETUGASLAPANGANOFFICIALCHECKOUTVERIFICATIONPHRASE42
