PORT=5001
NODE_ENV=development
DATABASE_URL=postgresql://attendance:attendance@127.0.0.1:5432/attendance
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Cross-origin UI (e.g. Vercel) + API on another host: use none in production
# COOKIE_SAME_SITE=none
CSRF_ENABLED=true
# Neon, Supabase, and other hosted Postgres often need SSL (auto-detected for neon.tech / supabase.co URLs)
# DATABASE_SSL=true
# Supabase (long-running API on your PC): Session pooler or direct connection, port 5432
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
ACTIVITY_LOG_ENABLED=true
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=6
OFFICE_RADIUS_METERS=500
# Up to this many meters of the device-reported GPS accuracy are added to the radius (capped).
OFFICE_RADIUS_GPS_BUFFER_CAP_METERS=200
MAX_GPS_ACCURACY_METERS=400
MAX_CLIENT_CLOCK_SKEW_MS=300000
MAX_IMPOSSIBLE_SPEED_MPS=50
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info

# Calendar day for “today” in attendance (office local timezone)
ATTENDANCE_CALENDAR_TZ=Asia/Jakarta

# Extra national holidays for payroll (comma-separated YYYY-MM-DD), e.g. cuti bersama
# ID_PAYROLL_EXTRA_HOLIDAYS=2026-05-28,2026-05-29
# Or edit backend/data/indonesia-payroll-holidays.json

# Petugas lapangan check-out: 9 fields separated by * (see fieldCheckoutPayload.js)

# Seeded demo passwords (new installs): admin / Admin123456 , employee / Employee123456

# Company name on exported slip gaji (Excel)
# PAYROLL_COMPANY_NAME=CV Harapan Jaya Sejahtera
