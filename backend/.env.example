PORT=5001
NODE_ENV=development
DATABASE_URL=postgresql://attendance:attendance@127.0.0.1:5432/attendance
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_ENABLED=true
ACTIVITY_LOG_ENABLED=true
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_COMPLEXITY=true
OFFICE_RADIUS_METERS=200
MAX_GPS_ACCURACY_METERS=100
MAX_CLIENT_CLOCK_SKEW_MS=300000
MAX_IMPOSSIBLE_SPEED_MPS=50
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info

# Seeded demo passwords (new installs): admin / Admin123!Secure , employee / Employee123!Secure
