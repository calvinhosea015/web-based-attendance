PORT=5001
NODE_ENV=development
DATABASE_URL=postgresql://attendance:attendance@127.0.0.1:5432/attendance
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Cross-origin UI (e.g. Vercel) + API (e.g. Railway): use none in production
# COOKIE_SAME_SITE=none
CSRF_ENABLED=true
# Neon and other hosted Postgres often need SSL (also auto-detected for neon.tech URLs)
# DATABASE_SSL=true
ACTIVITY_LOG_ENABLED=true
ACCESS_TOKEN_TTL_SEC=900
REFRESH_TOKEN_TTL_DAYS=14
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=6
OFFICE_RADIUS_METERS=350
# Up to this many meters of the device-reported GPS accuracy are added to the radius (capped).
OFFICE_RADIUS_GPS_BUFFER_CAP_METERS=120
MAX_GPS_ACCURACY_METERS=250
MAX_CLIENT_CLOCK_SKEW_MS=300000
MAX_IMPOSSIBLE_SPEED_MPS=50
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info

# Calendar day for “today” in attendance (office local timezone)
ATTENDANCE_CALENDAR_TZ=Asia/Jakarta

# Shared phrase petugas lapangan enter to check out (case-insensitive, min 42 characters)
FIELD_OFFICER_CHECKOUT_KEYWORD=PETUGASLAPANGANOFFICIALCHECKOUTVERIFICATIONPHRASE42

# Seeded demo passwords (new installs): admin / Admin123456 , employee / Employee123456
