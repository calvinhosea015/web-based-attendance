# Copy to .env.production and fill in before: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Public hostname (DNS A record must point to your server)
DOMAIN=attendance.example.com

# Secrets — use long random values in production
POSTGRES_PASSWORD=change-me-postgres-password
JWT_SECRET=change-me-jwt-secret-min-32-chars
COOKIE_SECRET=

# Optional app settings (see backend/.env.example)
ATTENDANCE_CALENDAR_TZ=Asia/Jakarta
CSRF_ENABLED=true
OFFICE_RADIUS_METERS=500
