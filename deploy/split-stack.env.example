# Split hosting: Vercel (UI) + local API + Postgres + R2 (optional files)
# API runs on your own machine (see backend/.env.production-local.example).
# Supabase hosts the database only — not the Node/Express API.
# Copy values into each platform’s dashboard — do not commit real secrets.

# --- Supabase (https://supabase.com) — database ---
# Project → Settings → Database → Connection string → URI
# For a long-running local API, use Session pooler or Direct (port 5432), not Transaction (6543).
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Neon (https://neon.tech) — database alternative ---
# Create a project → Connection string (pooled recommended).
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Local API (Windows / Mac / Linux) — copy backend/.env.production-local.example → backend/.env ---
# Use the SAME DATABASE_URL as below so production data is unchanged.
# Expose port 5001 with Cloudflare Tunnel or ngrok; set Vercel VITE_API_BASE to https://<tunnel-host>/api
# NODE_ENV=production
# SERVE_FRONTEND=false
# DATABASE_URL=<paste Supabase or Neon connection string>
# JWT_SECRET=<long random string>
# COOKIE_SECRET=<long random string>
# ALLOWED_ORIGINS=https://your-app.vercel.app
# COOKIE_SAME_SITE=none
# CSRF_ENABLED=true
# ATTENDANCE_CALENDAR_TZ=Asia/Jakarta
# OFFICE_RADIUS_METERS=500
# OFFICE_RADIUS_GPS_BUFFER_CAP_METERS=200
# MAX_GPS_ACCURACY_METERS=400

# --- Vercel (https://vercel.com) — project root: frontend/ ---
# Build env (Production):
# VITE_API_BASE=https://<your-tunnel-host>/api
# Wrong (causes 405 on login): omitting /api or using the Vercel URL instead of the API host

# --- Cloudflare R2 (optional; not required for current Excel exports) ---
# Use later for archived reports, uploads, or backups.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
