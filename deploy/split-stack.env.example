# Split hosting: Vercel (UI) + Railway (API) + Neon (Postgres) + R2 (optional files)
# Copy values into each platform’s dashboard — do not commit real secrets.

# --- Neon (https://neon.tech) ---
# Create a project → Connection string (pooled recommended for Railway).
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Railway (https://railway.app) — service root: backend/ ---
# Variables for the API service:
# NODE_ENV=production
# SERVE_FRONTEND=false
# DATABASE_URL=<paste Neon connection string>
# JWT_SECRET=<long random string>
# COOKIE_SECRET=<long random string>
# ALLOWED_ORIGINS=https://your-app.vercel.app
# COOKIE_SAME_SITE=none
# CSRF_ENABLED=true
# ATTENDANCE_CALENDAR_TZ=Asia/Jakarta

# --- Vercel (https://vercel.com) — project root: frontend/ ---
# Build env (Production):
# VITE_API_BASE=https://your-api.up.railway.app/api

# --- Cloudflare R2 (optional; not required for current Excel exports) ---
# Use later for archived reports, uploads, or backups.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=
